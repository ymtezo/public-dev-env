// ファイル: chrome/browser/ui/omnibox/omnibox_edit_controller.cc
// 検索エンジンへのクエリ送信を無効化

--- a/chrome/browser/ui/omnibox/omnibox_edit_controller.cc
+++ b/chrome/browser/ui/omnibox/omnibox_edit_controller.cc
@@ -100,6 +100,10 @@ void OmniboxEditController::OnAutocompleteAccept(
     const GURL& destination_url,
     TemplateURLRef::PostContent* post_content,
     WindowOpenDisposition disposition) {
+  // 検索クエリをブロック - URLのみ許可
+  if (!destination_url.SchemeIsHTTPOrHTTPS() && !destination_url.SchemeIsFile()) {
+    return;
+  }
   
   // 既存のコード...
 }

